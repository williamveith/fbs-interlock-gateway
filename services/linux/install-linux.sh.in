#!/usr/bin/env bash
set -euo pipefail

APP="@APP@"
INSTALL_DIR="@INSTALL_DIR@"
CONFIG_DIR="@CONFIG_DIR@"
CONFIG_PATH="@CONFIG_PATH@"
SERVICE_USER="@SERVICE_USER@"
SERVICE_GROUP="@SERVICE_GROUP@"
SERVICE_NAME="${APP}.service"

SOURCE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

BIN_SRC="${SOURCE_DIR}/${APP}"
CONFIG_SRC="${SOURCE_DIR}/config.yaml"
SERVICE_SRC="${SOURCE_DIR}/${SERVICE_NAME}"
UPDATE_SRC="${SOURCE_DIR}/update.sh"

UPDATE_SERVICE_SRC="${SOURCE_DIR}/${APP}-update.service"
UPDATE_TIMER_SRC="${SOURCE_DIR}/${APP}-update.timer"
UPDATE_SERVICE_NAME="${APP}-update.service"
UPDATE_TIMER_NAME="${APP}-update.timer"

echo "Installing ${APP} from:"
echo "  ${SOURCE_DIR}"
echo

if [[ "$(id -u)" -ne 0 ]]; then
  if command -v pkexec >/dev/null 2>&1; then
    exec pkexec env \
      DISPLAY="${DISPLAY:-}" \
      XAUTHORITY="${XAUTHORITY:-}" \
      bash "$0" "$@"
  else
    echo "Administrator privileges are required."
    echo "Run this script with:"
    echo "  sudo ${SOURCE_DIR}/install.sh"
    exit 1
  fi
fi

if [[ ! -f "$BIN_SRC" ]]; then
  echo "ERROR: Missing application binary:"
  echo "  $BIN_SRC"
  exit 1
fi

if [[ ! -f "$CONFIG_SRC" ]]; then
  echo "ERROR: Missing config file:"
  echo "  $CONFIG_SRC"
  exit 1
fi

if [[ ! -f "$SERVICE_SRC" ]]; then
  echo "ERROR: Missing service file:"
  echo "  $SERVICE_SRC"
  exit 1
fi

echo "Creating service group/user if needed..."

if ! getent group "$SERVICE_GROUP" >/dev/null; then
  groupadd --system "$SERVICE_GROUP"
fi

if ! id "$SERVICE_USER" >/dev/null 2>&1; then
  useradd \
    --system \
    --no-create-home \
    --home-dir "$INSTALL_DIR" \
    --shell /usr/sbin/nologin \
    --gid "$SERVICE_GROUP" \
    "$SERVICE_USER"
fi

echo "Creating install directory..."
install -d -o root -g "$SERVICE_GROUP" -m 0750 "$INSTALL_DIR"

echo "Installing application binary..."
install -o root -g root -m 0755 \
  "$BIN_SRC" \
  "$INSTALL_DIR/$APP"

echo "Creating config directory..."
install -d -o "$SERVICE_USER" -g "$SERVICE_GROUP" -m 0750 "$CONFIG_DIR"

echo "Installing config.yaml..."
if [[ ! -f "$CONFIG_PATH" ]]; then
  install -o "$SERVICE_USER" -g "$SERVICE_GROUP" -m 0640 \
    "$CONFIG_SRC" \
    "$CONFIG_PATH"
else
  echo "Existing config found; preserving:"
  echo "  $CONFIG_PATH"
  chown "$SERVICE_USER:$SERVICE_GROUP" "$CONFIG_PATH"
  chmod 0640 "$CONFIG_PATH"
fi

echo "Installing systemd service..."
install -o root -g root -m 0644 \
  "$SERVICE_SRC" \
  "/etc/systemd/system/$SERVICE_NAME"

if [[ -f "$UPDATE_SERVICE_SRC" ]]; then
  echo "Installing auto-update service..."
  install -o root -g root -m 0644 \
    "$UPDATE_SERVICE_SRC" \
    "/etc/systemd/system/$UPDATE_SERVICE_NAME"
fi

if [[ -f "$UPDATE_TIMER_SRC" ]]; then
  echo "Installing auto-update timer..."
  install -o root -g root -m 0644 \
    "$UPDATE_TIMER_SRC" \
    "/etc/systemd/system/$UPDATE_TIMER_NAME"
fi

if [[ -f "$UPDATE_SRC" ]]; then
  echo "Installing update.sh..."
  install -o root -g root -m 0755 \
    "$UPDATE_SRC" \
    "$INSTALL_DIR/update.sh"
fi

echo "Reloading systemd..."
systemctl daemon-reload

echo "Enabling service..."
systemctl enable "$SERVICE_NAME"

if [[ -f "/etc/systemd/system/$UPDATE_TIMER_NAME" ]]; then
  echo "Enabling auto-update timer..."
  systemctl enable --now "$UPDATE_TIMER_NAME"
fi

echo "Restarting service..."
systemctl restart "$SERVICE_NAME"

echo
echo "Install complete."
echo
systemctl --no-pager --full status "$SERVICE_NAME"
@echo off
setlocal EnableExtensions EnableDelayedExpansion

cd /d "@WINDOWS_INSTALL_DIR@" || exit /b 1

if not exist "logs" mkdir "logs"

set "LOG_FILE=logs\gateway.log"
set "CONFIG_PATH=@WINDOWS_INSTALL_DIR@\config.yaml"

set "RESTART_DELAY_SECONDS=2"
set "START_LIMIT_INTERVAL_SECONDS=60"
set "START_LIMIT_BURST=10"

set "START_WINDOW="
set /a START_COUNT=0

:restart

rem Get the current Unix timestamp.
for /f %%I in ('powershell.exe -NoLogo -NoProfile -NonInteractive -Command "[DateTimeOffset]::UtcNow.ToUnixTimeSeconds()"') do (
    set "CURRENT_TIME=%%I"
)

rem Start or reset the restart-rate window.
if not defined START_WINDOW (
    set "START_WINDOW=!CURRENT_TIME!"
    set /a START_COUNT=0
)

set /a WINDOW_AGE=CURRENT_TIME-START_WINDOW

if !WINDOW_AGE! GEQ !START_LIMIT_INTERVAL_SECONDS! (
    set "START_WINDOW=!CURRENT_TIME!"
    set /a START_COUNT=0
)

set /a START_COUNT+=1

rem Equivalent to StartLimitIntervalSec=60 and StartLimitBurst=10.
if !START_COUNT! GTR !START_LIMIT_BURST! (
    echo [%date% %time%] Restart limit exceeded: more than !START_LIMIT_BURST! starts in !START_LIMIT_INTERVAL_SECONDS! seconds. >> "!LOG_FILE!"
    exit /b 1
)

echo [%date% %time%] Starting @APP@.exe, attempt !START_COUNT! in the current restart window. >> "!LOG_FILE!"

"@APP@.exe" -config "!CONFIG_PATH!" >> "!LOG_FILE!" 2>&1

set "EXIT_CODE=!ERRORLEVEL!"

echo [%date% %time%] @APP@.exe exited with code !EXIT_CODE!. Restarting in !RESTART_DELAY_SECONDS! seconds. >> "!LOG_FILE!"

rem Equivalent to RestartSec=2.
timeout.exe /t !RESTART_DELAY_SECONDS! /nobreak >nul

goto restart
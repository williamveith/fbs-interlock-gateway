@echo off
setlocal

net session >nul 2>&1
if %errorlevel% neq 0 (
    echo.
    echo Administrator privileges are required.
    echo Right-click install.bat and select "Run as administrator."
    echo.
    pause
    exit /b 1
)

powershell.exe ^
    -NoLogo ^
    -NoProfile ^
    -ExecutionPolicy Bypass ^
    -File "%~dp0install.ps1"

if %errorlevel% neq 0 (
    echo.
    echo Installation failed.
    pause
    exit /b 1
)

echo.
echo Installation completed successfully.
pause